{
  "expo": {
    "name": "budgetify",
    "slug": "budjetify-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/budgetify_appIcon.png",
    "scheme": "budgetifyapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/budgetify_appIcon.png",
      "bundleIdentifier": "com.anonymous.budgetifyapp",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.530067833499-acm4u36k4a8n3ehni1q9rmchrp6ml4b5"
            ]
          }
        ]
      }
    },
    "android": {
      "icon": "./assets/images/budgetify_appIcon.png",
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.budgetifyapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b4f982eb-9874-4f56-aaa3-f0f26bade131"
      }
    }
  }
}
